# Default text normalization
* text=auto

# Source/config/docs should use LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.prisma text eol=lf
*.sql text eol=lf
*.sh text eol=lf

# Windows scripts keep CRLF if any are added later
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary/package artifacts
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.lockb binary